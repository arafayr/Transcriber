# === Transcription Provider API Keys ===
# Get your free keys from:
#   Groq:       https://console.groq.com/keys
#   Gemini:     https://aistudio.google.com/apikey
#   AssemblyAI: https://www.assemblyai.com/dashboard/signup
#   Deepgram:   https://console.deepgram.com/signup
#   Gladia:     https://app.gladia.io/auth/signup

GROQ_API_KEY=
GEMINI_API_KEY=
ASSEMBLYAI_API_KEY=
DEEPGRAM_API_KEY=
GLADIA_API_KEY=

# === Service Config ===
# Provider to use: auto | groq | gemini | assemblyai | deepgram | gladia
DEFAULT_PROVIDER=auto

# Maximum allowed video duration in seconds (default: 3600 = 1 hour)
MAX_DURATION_SECONDS=3600

# Maximum upload file size in MB (default: 500)
MAX_UPLOAD_SIZE_MB=500

# Temporary directory for downloaded audio files
TEMP_DIR=/tmp/transcriber
